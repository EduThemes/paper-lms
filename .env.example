# Paper LMS — example environment configuration.
# Copy to `.env` and edit. Never commit `.env` to source control.

# ─── Core ─────────────────────────────────────────────────────────────────
# HTTP port the Go server listens on.
PORT=3000

# Postgres connection string. The Docker compose stack uses port 5433.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=...
DATABASE_URL=postgres://paper:paper@localhost:5433/paper_lms?sslmode=disable

# JWT signing secret. REQUIRED in production — use at least 32 random bytes.
# Generate with: openssl rand -hex 32
# In development this can be left as the placeholder; the server will
# auto-generate an ephemeral secret and warn at startup.
JWT_SECRET=change-me-in-production

# `development` or `production`. Production mode enforces JWT_SECRET,
# DATABASE_URL, and FRONTEND_URL must be configured non-defaults.
ENVIRONMENT=development

# Public URL of the React frontend, used for CORS allowlist and email links.
FRONTEND_URL=http://localhost:5174

# ─── Database migrations ──────────────────────────────────────────────────
# `true` = GORM AutoMigrate runs at startup. Convenient for fast model-add
#          iteration; non-fatal but expect warnings about constraint-shape
#          mismatches between GORM tags and the SQL chain (e.g. GORM's
#          `uniqueIndex` produces `uni_*` while the SQL chain uses `idx_*`).
# `false` = SQL chain via `make migrate-up` is the source of truth.
#          Recommended for prod AND most dev workflows.
AUTO_MIGRATE=false

# ─── File storage ─────────────────────────────────────────────────────────
# `local` writes to FILE_STORAGE_PATH on disk. `s3` uses the S3_* settings below
# (works with S3, MinIO, Cloudflare R2, Backblaze B2, GCS S3-compat).
STORAGE_BACKEND=local
FILE_STORAGE_PATH=./storage/files

# Max upload size in MB (per file).
MAX_UPLOAD_SIZE_MB=500

# S3-compatible storage (only when STORAGE_BACKEND=s3)
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=                # leave blank for AWS S3; set for MinIO/R2/etc.
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─── Email (SMTP) ─────────────────────────────────────────────────────────
# Used for weekly digests, notifications, password resets.
# Leave SMTP_ENABLED=false to disable email entirely.
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@paperlms.org

# ─── SAML SSO (optional) ──────────────────────────────────────────────────
# Set these to enable SAML 2.0 single sign-on for your district IdP.
SAML_ENTITY_ID=
SAML_CERT_FILE=
SAML_KEY_FILE=

# ─── Encryption at rest (REQUIRED for MFA / OIDC / passkeys) ──────────────
# AES-256-GCM key (32 bytes, base64). Encrypts TOTP secrets, OIDC client
# secrets, LDAP bind passwords, and any other DB-resident secret.
# Generate with:
#   go run ./cmd/encrypt-ldap-passwords -gen-key
# Fatal at boot in production if unset; warning in development.
MFA_ENCRYPTION_KEY=

# ─── Passkeys / WebAuthn (optional) ───────────────────────────────────────
# PASSKEY_RPID is the eTLD+1 of the site origin — "localhost" in dev,
# "paperlms.example.edu" in prod. PASSKEY_RPORIGINS is a comma-separated
# list of full origins the browser will connect from; FRONTEND_URL is
# always implicitly included.
PASSKEY_RPID=localhost
PASSKEY_RPORIGINS=

# ─── OIDC (optional) ──────────────────────────────────────────────────────
# Base URL the OIDC client uses to construct redirect_uri. Should resolve
# to a public hostname callable by the IdP. Defaults to http://localhost:3000
# when unset (dev only).
OIDC_REDIRECT_BASE=

# ─── Scheduler ────────────────────────────────────────────────────────────
# DISABLE_SCHEDULER=1 short-circuits the background digest scheduler.
# Required for CI/test runs and multi-replica deployments that delegate
# digest dispatch to an external cron (until leader-election lands).
# Note: graceful-shutdown wiring runs regardless of this flag.
DISABLE_SCHEDULER=

# ─── AI Assist (optional) ─────────────────────────────────────────────────
# Anthropic API key powers the Outline / Summarize / Rewrite features in the
# rich content editor. Without a key, AI Assist endpoints return 503 cleanly.
# Get one at https://console.anthropic.com.
ANTHROPIC_API_KEY=

# ─── Observability (optional but recommended in production) ───────────────
# Phase 11 / G2. /metrics is always served (Prometheus exposition).
# OTEL traces are exported only when an OTLP endpoint is configured.
#
# OBSERVABILITY_OTLP_ENDPOINT
#   Base URL of an OTLP/HTTP collector. Examples:
#     http://otel-collector:4318  (local docker-compose collector)
#     https://api.honeycomb.io    (Honeycomb direct ingest)
#   Leave empty for development — spans are then no-ops.
# OBSERVABILITY_TRACES_STDOUT
#   "true" routes traces to stdout (JSON) in addition to OTLP, for
#   local "did the span fire?" debugging.
# OBSERVABILITY_SERVICE_NAME
#   Defaults to "paper-lms". Set per-environment to disambiguate in
#   the collector (e.g. "paper-lms-staging", "paper-lms-prod").
# OBSERVABILITY_SAMPLE_RATIO
#   Float in [0.0, 1.0]; default 1.0 (sample everything). Drop in
#   high-traffic prod to control collector cost.
OBSERVABILITY_OTLP_ENDPOINT=
OBSERVABILITY_TRACES_STDOUT=false
OBSERVABILITY_SERVICE_NAME=
OBSERVABILITY_SAMPLE_RATIO=
